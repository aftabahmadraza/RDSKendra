---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog" description="RDS Kendra के सभी लेख एक जगह।">
  <h1 class="text-2xl font-bold mb-6">सभी Articles</h1>
  <ul class="space-y-4">
    {posts.map((post) => (
      <li class="border-b border-slate-200 dark:border-slate-800 pb-4">
        <a href={`/blog/${post.slug}/`} class="font-medium text-lg hover:text-brand-600">
          {post.data.title}
        </a>
        <p class="text-sm text-slate-500 mt-1">{post.data.description}</p>
      </li>
    ))}
  </ul>
</BaseLayout>
